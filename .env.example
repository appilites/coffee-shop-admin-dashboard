# Supabase Configuration
# Get these values from: Supabase Dashboard â†’ Project Settings â†’ API

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase Anon/Publishable Key (for client-side operations)
# Use either NEXT_PUBLIC_SUPABASE_ANON_KEY (old format) or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY (new format)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# OR
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key

# Supabase Service Role Key (for admin operations - bypasses RLS)
# Use either SUPABASE_SERVICE_ROLE_KEY (old format) or SUPABASE_SECRET_KEY (new format)
# âš ï¸ IMPORTANT: Never commit this key to GitHub! Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# OR
# SUPABASE_SECRET_KEY=your_supabase_secret_key

# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=http://localhost:3000
# For production, set NEXTAUTH_URL to your actual domain:
# NEXTAUTH_URL=https://your-domain.com
